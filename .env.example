SECRET_KEY=change-this-development-secret-key-before-deployment
ACCESS_TOKEN_EXPIRE_MINUTES=60
COOKIE_SECURE=false

# Local development database. A relative SQLite file is created automatically.
DATABASE_URL=sqlite:///./freshlink.db

# Later, replace DATABASE_URL with the PostgreSQL URL supplied by Aiven:
# DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
